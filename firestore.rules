rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }

    match /test/connection {
      allow read: if isSignedIn();
    }

    function isSuperAdmin(email) {
      return email == 'abdalrhmanmaaith24@gmail.com';
    }

    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'abdalrhmanmaaith1@gmail.com' ||
        isSuperAdmin(request.auth.token.email) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') in ['admin', 'moderator'])
      );
    }

    function isModerator() {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'moderator')
      );
    }

    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function getUser(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    
    function isUnblocked() {
      return isSignedIn() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBlocked', false) == false &&
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('timeoutUntil', null) == null || 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.timeoutUntil <= request.time)
        )
      );
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.keys().hasAll(['uid', 'email', 'role']) &&
             data.email is string &&
             data.role in ['admin', 'moderator', 'user'];
    }

    function isValidRound(data) {
      let requiredFields = ['name', 'duration', 'breakAfter', 'breakDuration', 'startTime', 'status', 'creatorId', 'participants'];
      return data.keys().hasAll(requiredFields) &&
             data.name is string && data.name.size() <= 128 &&
             data.duration is int && data.duration > 0 &&
             data.breakAfter is int && data.breakAfter >= 0 &&
             data.breakDuration is int && data.breakDuration >= 0 &&
             data.status in ['active', 'completed', 'cancelled'] &&
             data.creatorId == request.auth.uid &&
             data.participants is list &&
             data.participants.size() > 0 &&
             data.participants[0] == request.auth.uid &&
             (data.startTime == request.time || data.startTime is timestamp);
    }

    function isValidMessage(data) {
      let requiredFields = ['text', 'senderId', 'senderName', 'senderRole', 'timestamp'];
      return data.keys().hasAll(requiredFields) &&
             data.text is string && data.text.size() <= 2000 &&
             data.senderId == request.auth.uid &&
             data.senderName is string &&
             data.senderRole is string &&
             data.timestamp == request.time;
    }

    function isValidTicket(data) {
      let requiredFields = ['message', 'senderId', 'senderEmail', 'status', 'timestamp'];
      return data.keys().hasAll(requiredFields) &&
             data.message is string && data.message.size() <= 5000 &&
             data.senderId == request.auth.uid &&
             data.status in ['open', 'resolved'] &&
             data.timestamp == request.time;
    }

    function isValidContent(data) {
      let requiredFields = ['type', 'content', 'creatorId', 'timestamp'];
      return data.keys().hasAll(requiredFields) &&
             data.type in ['schedule', 'expression', 'community'] &&
             data.content is string && data.content.size() <= 100000 &&
             data.creatorId == request.auth.uid &&
             (data.timestamp == request.time || data.timestamp is timestamp);
    }

    function isValidComment(data) {
      let requiredFields = ['content', 'creatorId', 'creatorName', 'timestamp', 'replies'];
      return data.keys().hasAll(requiredFields) &&
             data.content is string && data.content.size() <= 5000 &&
             data.creatorId == request.auth.uid &&
             data.replies is list &&
             (data.timestamp == request.time || data.timestamp is timestamp);
    }

    function isValidNotification(data) {
      let requiredFields = ['userId', 'title', 'message', 'type', 'read', 'timestamp'];
      return data.keys().hasAll(requiredFields) &&
             data.userId is string &&
             data.title is string && data.title.size() <= 256 &&
             data.message is string && data.message.size() <= 1024 &&
             data.type in ['like', 'round_start', 'round_end', 'break_start', 'break_end', 'profile_update'] &&
             data.read is bool &&
             (data.timestamp == request.time || data.timestamp is timestamp);
    }

    // --- Collection Routes ---

    match /app/config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isModerator());
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isModerator() && !isSuperAdmin(existing().email)) || (isOwner(userId) && 
        isValidUser(incoming())
      );
    }

    match /rounds/{roundId} {
      allow read: if isSignedIn();
      allow create: if isUnblocked() && isValidRound(incoming());
      allow update: if isSignedIn() && (
        isModerator() ||
        (isUnblocked() && existing().creatorId == request.auth.uid && isValidRound(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'participants', 'name', 'duration', 'breakAfter', 'breakDuration'])
        )) ||
        (isUnblocked() && incoming().diff(existing()).affectedKeys().hasOnly(['participants']) && incoming().participants.size() >= existing().participants.size()) ||
        (isUnblocked() && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == 'completed')
      );
      allow delete: if isModerator();

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isUnblocked() && isValidMessage(incoming());
        allow delete: if isModerator();
      }
    }

    match /support/{ticketId} {
      allow read: if isModerator() || (isSignedIn() && existing().senderId == request.auth.uid);
      allow create: if isSignedIn() && isValidTicket(incoming()); // Banned users CAN create support tickets
      allow update: if isModerator();

      match /messages/{messageId} {
        allow read: if isModerator() || (isSignedIn() && get(/databases/$(database)/documents/support/$(ticketId)).data.senderId == request.auth.uid);
        allow create: if isModerator() || (isSignedIn() && get(/databases/$(database)/documents/support/$(ticketId)).data.senderId == request.auth.uid && isValidMessage(incoming()));
        allow delete: if isModerator();
      }
    }

    match /content/{contentId} {
      allow read: if isSignedIn();
      allow create: if isUnblocked() && isValidContent(incoming());
      allow update: if isModerator() || (isSignedIn() && isUnblocked() && (
        (existing().creatorId == request.auth.uid && isValidContent(incoming())) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'commentCount']))
      ));
      allow delete: if isModerator() || (isSignedIn() && existing().creatorId == request.auth.uid);

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isUnblocked() && isValidComment(incoming());
        allow update: if isModerator() || (isSignedIn() && isUnblocked() && (
          (existing().creatorId == request.auth.uid && isValidComment(incoming())) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['replies']))
        ));
        allow delete: if isModerator() || (isSignedIn() && existing().creatorId == request.auth.uid);
      }
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isModerator() || (isSignedIn() && isUnblocked() && isValidNotification(incoming()));
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
