rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }

    match /test/connection {
      allow read: if isSignedIn();
    }

    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'abdalrhmanmaaith24@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
      );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function getUser(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    
    function isUnblocked() {
      return isSignedIn() && (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) || getUser(request.auth.uid).get('isBlocked', false) == false);
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      let requiredFields = ['uid', 'email', 'role', 'isBlocked', 'restrictedActions', 'hasFlame', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['admin', 'user'] &&
             data.isBlocked is bool &&
             data.restrictedActions is list &&
             data.hasFlame is bool &&
             (data.createdAt is timestamp || data.createdAt is string) &&
             (!data.keys().contains('displayName') || (data.displayName is string && data.displayName.size() <= 128)) &&
             (!data.keys().contains('photoURL') || (data.photoURL is string && data.photoURL.size() <= 1024));
    }

    function isValidRound(data) {
      let requiredFields = ['name', 'duration', 'breakAfter', 'breakDuration', 'startTime', 'status', 'creatorId', 'participants'];
      return data.keys().hasAll(requiredFields) &&
             data.name is string && data.name.size() <= 128 &&
             data.duration is int && data.duration > 0 &&
             data.breakAfter is int && data.breakAfter >= 0 &&
             data.breakDuration is int && data.breakDuration >= 0 &&
             data.status in ['active', 'completed', 'cancelled'] &&
             data.creatorId == request.auth.uid &&
             data.participants is list &&
             data.participants.size() > 0 &&
             data.participants[0] == request.auth.uid &&
             (data.startTime == request.time || data.startTime is timestamp);
    }

    function isValidMessage(data) {
      let requiredFields = ['text', 'senderId', 'senderName', 'senderRole', 'timestamp'];
      return data.keys().hasAll(requiredFields) &&
             data.text is string && data.text.size() <= 2000 &&
             data.senderId == request.auth.uid &&
             data.senderName is string &&
             data.senderRole is string &&
             data.timestamp == request.time;
    }

    function isValidTicket(data) {
      let requiredFields = ['message', 'senderId', 'senderEmail', 'status', 'timestamp'];
      return data.keys().hasAll(requiredFields) &&
             data.message is string && data.message.size() <= 5000 &&
             data.senderId == request.auth.uid &&
             data.status in ['open', 'resolved'] &&
             data.timestamp == request.time;
    }

    function isValidContent(data) {
      let requiredFields = ['type', 'content', 'creatorId', 'timestamp'];
      return data.keys().hasAll(requiredFields) &&
             data.type in ['schedule', 'expression', 'community'] &&
             data.content is string && data.content.size() <= 100000 &&
             data.creatorId == request.auth.uid &&
             (data.timestamp == request.time || data.timestamp is timestamp);
    }

    function isValidComment(data) {
      let requiredFields = ['content', 'creatorId', 'creatorName', 'timestamp', 'replies'];
      return data.keys().hasAll(requiredFields) &&
             data.content is string && data.content.size() <= 5000 &&
             data.creatorId == request.auth.uid &&
             data.replies is list &&
             (data.timestamp == request.time || data.timestamp is timestamp);
    }

    // --- Collection Routes ---

    match /app/config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isOwner(userId) && isValidUser(incoming()) && (incoming().role == 'user' || request.auth.token.email == 'abdalrhmanmaaith24@gmail.com');
      allow update: if isAdmin() || (isOwner(userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'hasFlame']) && 
        isValidUser(incoming())
      );
    }

    match /rounds/{roundId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isUnblocked() && isValidRound(incoming());
      allow update: if isSignedIn() && isUnblocked() && (
        isAdmin() ||
        (existing().creatorId == request.auth.uid && isValidRound(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'participants', 'name', 'duration', 'breakAfter', 'breakDuration'])
        )) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['participants']) && incoming().participants.size() >= existing().participants.size())
      );

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isUnblocked() && isValidMessage(incoming());
      }
    }

    match /support/{ticketId} {
      allow read: if isAdmin() || (isSignedIn() && existing().senderId == request.auth.uid);
      allow create: if isSignedIn() && isUnblocked() && isValidTicket(incoming());
      allow update: if isAdmin();
    }

    match /content/{contentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isUnblocked() && isValidContent(incoming());
      allow update: if isAdmin() || (isSignedIn() && isUnblocked() && (
        (existing().creatorId == request.auth.uid && isValidContent(incoming())) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'commentCount']))
      ));
      allow delete: if isAdmin() || (isSignedIn() && existing().creatorId == request.auth.uid);

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isUnblocked() && isValidComment(incoming());
        allow update: if isAdmin() || (isSignedIn() && isUnblocked() && (
          (existing().creatorId == request.auth.uid && isValidComment(incoming())) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['replies']))
        ));
      }
    }
  }
}
