rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'abdalrhmanmaaith24@gmail.com' ||
        getUserData(request.auth.uid).role == 'admin'
      );
    }

    function isUnblocked() {
      return isSignedIn() && getUserData(request.auth.uid).get('isBlocked', false) == false;
    }

    function isRestricted(action) {
      return isSignedIn() && action in getUserData(request.auth.uid).get('restrictedActions', []);
    }

    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['admin', 'user'] &&
             (!data.keys().contains('displayName') || (data.displayName is string && data.displayName.size() <= 128)) &&
             (!data.keys().contains('photoURL') || (data.photoURL is string && data.photoURL.size() <= 1024));
    }

    function isValidRound(data) {
      return data.keys().hasAll(['name', 'duration', 'creatorId', 'status']) &&
             data.name is string && data.name.size() <= 128 &&
             data.duration is int && data.duration > 0 &&
             data.creatorId == request.auth.uid &&
             data.status in ['active', 'completed', 'cancelled'];
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'timestamp']) &&
             data.text is string && data.text.size() <= 1000 &&
             data.senderId == request.auth.uid &&
             data.timestamp == request.time;
    }

    // --- Matches ---

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && incoming().role == 'user';
      allow update: if isSignedIn() && (
        (request.auth.uid == userId &&
         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']) &&
         isValidUser(incoming())) ||
        (isAdmin() && isValidUser(incoming()))
      );
    }

    match /rounds/{roundId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isUnblocked() && !isRestricted('createRound') && isValidRound(incoming());
      allow update: if isSignedIn() && isUnblocked() && (
        (existing().creatorId == request.auth.uid && isValidRound(incoming())) ||
        (isAdmin() && isValidRound(incoming())) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['participants'])) // Join round
      );
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isUnblocked() && !isRestricted('chat') && isValidMessage(incoming());
      }
    }

    match /support/{ticketId} {
      allow read: if isSignedIn() && (incoming().senderId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isUnblocked() && incoming().senderId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /content/{contentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isUnblocked() && incoming().creatorId == request.auth.uid;
      allow update: if isSignedIn() && (existing().creatorId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().creatorId == request.auth.uid || isAdmin());
    }
  }
}
